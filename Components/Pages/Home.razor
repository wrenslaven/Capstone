@using System.Text.Json

@page "/"
@rendermode InteractiveServer

<PageTitle>CFBGuessr</PageTitle>

<div class="container text-center my-4" style="max-width: 700px;">

    <div class="mb-4">
        <h1 class="fw-bold">CFBGuessr</h1>
        <div class="d-flex justify-content-center gap-4 text-muted">
            <h4>Score: @total_score</h4>
            <h4>Guesses: @guesses_remaining</h4>
        </div>
    </div>

    <datalist id="team-suggestions">
        @foreach (string team in teamNames)
        {
            <option value="@team" />
        }
    </datalist>

    @if (!playerWon && guesses_remaining > 0){<div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title">Guess a Division 1 FBS Team</h5>
            
            <form @onsubmit="SubmitGuess">
                <div class="input-group my-3 mx-auto" style="max-width: 400px;">
                   <input type="text" 
                    class="form-control" 
                    placeholder="Enter a team name" 
                    @bind="playerGuess" 
                    list="team-suggestions" />
                    <button class="btn btn-success" type="submit">Guess</button>
                </div>
            </form>
            
            @if (!string.IsNullOrEmpty(feedbackMessage))
            {
                <p class="text-danger fw-bold mb-0">@feedbackMessage</p>
            }
        </div>
    </div>}

    <div class="d-flex flex-column gap-3">
        
        <div>
            @if (schedule_revealed | all_revealed)
            {
                <table class="table table-bordered table-sm text-center align-middle mx-auto shadow-sm">
                    <thead class="table-dark">
                        <tr><th colspan="4">Weekly Scores</th></tr>
                    </thead>
                    <tbody>
                        @for (int r = 0; r < 3; r++)
                        {
                            <tr>
                                @for (int c = 0; c < 4; c++)
                                {
                                    int index = (r * 4) + c;
                                    <td>
                                        @if (index < allPuzzles[puzzleIndex].weekly_scores.Length)
                                        {
                                            <span class="text-muted" style="font-size: 0.8em;">Week @(index + 1)</span><br />
                                            <strong>@allPuzzles[puzzleIndex].weekly_scores[index]</strong>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <button class="btn btn-outline-primary w-50" @onclick="RevealSchedule">Reveal Weekly Scores (-50 pts)</button>
            }
        </div>

        <div>
            @if (coach_revealed | all_revealed)
            {
                <h5 class="p-2 border rounded mx-auto" style="max-width: 400px;">
                    <strong>Coach:</strong> @allPuzzles[puzzleIndex].head_coach
                </h5>
            }
            else
            {
                <button class="btn btn-outline-primary w-50" @onclick="RevealCoach">Reveal Head Coach (-100 pts)</button>
            }
        </div>

        <div>
            @if (rankings_revealed | all_revealed)
            {
                <table class="table table-bordered table-sm text-center align-middle mx-auto shadow-sm">
                    <thead class="table-dark">
                        <tr><th colspan="6">Weekly Rankings (AP Poll)</th></tr>
                    </thead>
                    <tbody>
                        @for (int r = 0; r < 3; r++)
                        {
                            <tr>
                                @for (int c = 0; c < 6; c++)
                                {
                                    int index = (r * 6) + c;
                                    <td>
                                        @if (index < allPuzzles[puzzleIndex].weekly_rankings.Length)
                                        {
                                            <span class="text-muted" style="font-size: 0.8em;">Week @(index + 1)</span><br />
                                            int ranking = @allPuzzles[puzzleIndex].weekly_rankings[index];
                                            if (ranking == -1)
                                            {
                                                <strong>Unranked</strong>
                                            }
                                            else
                                            {
                                                <strong>@ranking</strong>
                                            }
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <button class="btn btn-outline-primary w-50" @onclick="RevealRankings">Reveal Weekly Rankings (-50 pts)</button>
            }
        </div>

        <!-- Conference -->
        <div>
            @if (conference_revealed | all_revealed)
            {
                <h5 class="p-2 border rounded mx-auto" style="max-width: 400px;">
                    <strong>Conference:</strong> @allPuzzles[puzzleIndex].conference
                </h5>
            }
            else
            {
                <button class="btn btn-outline-primary w-50" @onclick="RevealConference">Reveal Conference (-100 pts)</button>
            }
        </div>

        <!-- Reveal All -->
        <div class="mt-3">
            @if (all_revealed)
            {
                <div class="d-flex flex-wrap justify-content-center gap-3 p-3 border rounded">
                    <h5 class="w-100 text-center mb-0">Bonus Stats</h5>
                    <span><strong>Mascot:</strong> @allPuzzles[puzzleIndex].reveal_all[0]</span>
                    <span><strong>Rival(s):</strong> @allPuzzles[puzzleIndex].reveal_all[1]</span>
                    <span><strong>Stadium:</strong> @allPuzzles[puzzleIndex].reveal_all[2]</span>
                </div>
            }
            else
            {
                <button class="btn btn-danger w-50 shadow-sm" @onclick="RevealAll">Reveal All (& Mascot, Rivals, Stadium)</button>
            }
        </div>
    </div>

    @if (showResults){
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.75);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg">
                
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">
                        @(playerWon ? "You Win!" : "Game Over")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseResults"></button>
                </div>
                
                <div class="modal-body text-center">
                    <p class="fs-5">The team was:</p>
                    <h2 class="fw-bold text-success">@allPuzzles[puzzleIndex].answer (@allPuzzles[puzzleIndex].answer_year)</h2>
                    
                    <hr />
                    
                    <p><strong>Final Score:</strong> @total_score</p>
                    <p><strong>Guesses Used:</strong> @(10 - guesses_remaining) / 10</p>
                </div>
                
                <div class="modal-footer justify-content-center">
                    <button class="btn btn-primary" @onclick="CloseResults">Review Team Stats</button>
                </div>
                
            </div>
        </div>
    </div>}
</div>


@code{
     private bool schedule_revealed = false;
    private void RevealSchedule(){
        schedule_revealed = true;
        total_score -= 50;
    }
    private bool coach_revealed = false;
    private void RevealCoach(){
        coach_revealed = true;
        total_score -= 100;
    }
    private bool rankings_revealed = false;
    private void RevealRankings(){
        rankings_revealed = true;
        total_score -= 50;
    }

    private bool conference_revealed = false;
    private void RevealConference(){
        conference_revealed = true;
        total_score -= 100;
    }
    private bool all_revealed = false;
    private void RevealAll(){
        all_revealed = true;
        total_score = 0;
    }
    private int total_score = 300;
    private int guesses_remaining = 10;
    private string playerGuess = "";
    private string feedbackMessage = "";
    private bool showResults = false;
    private bool playerWon = false;
    
    private void SubmitGuess()
    {
        if (string.IsNullOrWhiteSpace(playerGuess))
        {
            return;
        }

        if (playerGuess.Equals(allPuzzles[puzzleIndex].answer, StringComparison.OrdinalIgnoreCase)) 
        {
            feedbackMessage = "Correct!";
            guesses_remaining -= 1;
            all_revealed = true;
            showResults = true;
            playerWon = true;
        }
        else
        {
            feedbackMessage = "Incorrect";
            playerGuess = "";
            guesses_remaining -= 1;
            if (guesses_remaining <= 0)
            {
                all_revealed = true;
                showResults = true;
                playerWon = false;
            }
        }
        Console.WriteLine(allPuzzles[puzzleIndex].head_coach);
    }
    int puzzleIndex = 1;

    public record PuzzleData(string answer, int answer_year, string[] weekly_scores, string head_coach, int[] weekly_rankings, string conference, string[] reveal_all);
    List<PuzzleData> allPuzzles = JsonSerializer.Deserialize<List<PuzzleData>>(File.ReadAllText("wwwroot/teamlist.json"))!;
    
    string[] teamNames = File.ReadAllLines("wwwroot/teams.txt");
    
    private void CloseResults(){
        showResults = false;
    }
}

